# ========================
# Face ID Project - Environment Configuration
# ========================

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=face_id
POSTGRES_USER=face_id_user
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Camera Service
CAMERA_SERVICE_HOST=camera-service
CAMERA_SERVICE_PORT=8001
CAMERA_FRAME_WIDTH=640
CAMERA_FRAME_HEIGHT=480
CAMERA_FPS=30
CAMERA_DEPTH_ENABLED=true

# Face Processing Service
FACE_SERVICE_HOST=face-service
FACE_SERVICE_PORT=8002
FACE_DETECTION_CONFIDENCE=0.7
FACE_RECOGNITION_THRESHOLD=0.6
ANTI_SPOOF_THRESHOLD=0.5
FACE_EMBEDDING_SIZE=512

# Auth Service
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=8003

# API Gateway
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Logging
LOG_LEVEL=INFO
